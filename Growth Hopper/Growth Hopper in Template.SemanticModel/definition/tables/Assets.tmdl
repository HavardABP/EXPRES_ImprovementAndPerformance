				    #"Removed Duplicates" = Table.Distinct(#"Removed Other Columns", {"Asset"}),
				    #"Added Conditional Column" = Table.AddColumn(#"Removed Duplicates", "Well", each if [Asset] = "Valhall" then "Well_1" else if [Asset] = "Eiga" then "Well_2" else if [Asset] = "Ula" then "Well_3" else if [Asset] = "Alvheim" then "Well_4" else if [Asset] = "Skarv" then "Well_5" else if [Asset] = "Yggdrasil" then "Well_6" else null, type text)
