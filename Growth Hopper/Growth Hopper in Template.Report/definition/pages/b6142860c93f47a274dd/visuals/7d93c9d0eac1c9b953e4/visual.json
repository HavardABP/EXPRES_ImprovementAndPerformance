              {
                "textRuns": [
                  {
                    "value": "Applying the Data Analytics Power BI theme",
                    "textStyle": {
                      "fontSize": "14pt",
                      "textDecoration": "underline"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "There are two methods for applying the theme in your .pbix file. You can read more about report themes at Microsoft's ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  },
                  {
                    "value": "Use report themes in Power BI Desktop",
                    "textStyle": {
                      "fontSize": "14pt"
                    },
                    "url": "https://docs.microsoft.com/en-us/power-bi/create-reports/desktop-report-themes"
                  },
                  {
                    "value": " page. ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "As per February 2026 it is yet not possible to import theme in Power BI Service - this needs to be done in Power BI Desktop.",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "1. JSON file method",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "This method is recommended when creating new .pbix files. It can be used on existing .pbix files but there is the possibility that there will be unwanted changes. ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Instructions: ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Always make a backup copy and test applying the theme on that copy when using an existing .pbix file. ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Download the ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  },
                  {
                    "value": "Aker BP theme",
                    "textStyle": {
                      "fontSize": "14pt"
                    },
                    "url": "https://akerbp.sharepoint.com/sites/abp-team-1255/_layouts/15/download.aspx?UniqueId=84282cde725b4f8695cf83d7cb4b6f4c&e=GyADoN"
                  },
                  {
                    "value": " file locally.  ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "In Power BI desktop, select View from the menu,",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  },
                  {
                    "value": " ",
                    "textStyle": {
                      "fontSize": "14pt",
                      "color": "#171717"
                    }
                  },
                  {
                    "value": "then from the Themes drop-down button, select Browse for themes. ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "A new window appears where you can choose the .json file that you recently downloaded.  ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Clicking open will attempt to install the theme, and a success message will be displayed if the theme is installed.  ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "2. Manual update method ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "This method is recommended for existing .pbix files when only a few settings will be changed or when unwanted changes occur when trying to use the JSON file method. ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Instructions: ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Always make a backup copy and test applying the theme on that copy when using an existing .pbix file. ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Open your .pbix file in Power BI desktop, select View from the menu,",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  },
                  {
                    "value": " ",
                    "textStyle": {
                      "fontSize": "14pt",
                      "color": "#171717"
                    }
                  },
                  {
                    "value": "then from the Themes drop-down button, select Customize current theme. ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Follow the same steps above in this file to see the theme settings. ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Choose which settings you want to change using this file as a reference.",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ],
                "listType": "bullet"
              }
            ]
          }
